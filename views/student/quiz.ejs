<!DOCTYPE html>
<html>
<head><title><%= quiz.title %></title><meta name="viewport" content="width=device-width,initial-scale=1"><link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"></head>
<body>
<div class="portal-container" style="max-width:800px;margin:0 auto;padding:20px">
  <div class="portal-header">
    <h1><i class="fas fa-question-circle"></i> <%= quiz.title %></h1>
    <p style="margin:0;opacity:.9"><%= quiz.className.replace('Grade ','') %>ème · <% if (quiz.semester) { %>Semestre <%= quiz.semester %><% } else { %>Quiz<% } %></p>
  </div>
  <div class="portal-quote" style="background:#fcf9f5;border:1px solid #e8ddd0;border-radius:10px;padding:.75rem 1rem;margin-bottom:1.5rem">
    <p class="quote-banner-label">Daily Mathematical Thought</p>
    <p class="quote-banner-text">"<%= dailyMathQuote.text %>"</p>
    <p class="quote-banner-author"><%= dailyMathQuote.author %></p>
  </div>

  <% if (error) { %>
    <div class="alert error" style="background:linear-gradient(135deg,#fff0f0,#ffe0e0);color:#c0392b;padding:12px;border-radius:10px;margin-bottom:1rem;font-weight:600;border:1px solid #fcc"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
  <% } %>

  <% if (!result && !error) { %>
    <script>
    (function() {
      const done = JSON.parse(localStorage.getItem('ehmej_quizzes') || '[]');
      if (done.includes('<%= quiz._id %>')) {
        document.write('<div class="alert error" style="background:linear-gradient(135deg,#fff0f0,#ffe0e0);color:#c0392b;padding:12px;border-radius:10px;margin-bottom:1rem;font-weight:600;border:1px solid #fcc"><i class="fas fa-info-circle"></i> You already completed this quiz on this device.</div><div style="text-align:center;padding:2rem"><a href="/portal/<%= quiz.className.toLowerCase().replace(" ","-") %>" class="button-link" style="display:inline-block;padding:.6rem 1.5rem;background:#0b2a4a;color:#fff;border-radius:10px;text-decoration:none"><i class="fas fa-arrow-left"></i> Back to Portal</a></div>');
      }
    })();
    </script>
  <% } %>

  <% if (result) { %>
    <div class="quiz-result" style="background:#fff;border-radius:16px;padding:2rem;box-shadow:0 10px 30px rgba(0,0,0,.08);text-align:center;margin-bottom:1.5rem">
      <div style="font-size:3rem;margin-bottom:.5rem"><%= (result.score/result.total*100)>=50?'🎉':'💪' %></div>
      <h2 style="color:#0b2a4a;margin-bottom:.5rem">Your Score</h2>
      <div style="font-size:2.5rem;font-weight:800;color:<%= (result.score/result.total*100)>=50?'#27ae60':(result.score/result.total*100)>=40?'#f39c12':'#e74c3c' %>"><%= result.score %> / <%= result.total %></div>
      <div style="margin-top:.3rem;font-size:1.1rem;color:#667588"><%= Math.round(result.score/result.total*100) %>%</div>
      <a href="/portal/<%= quiz.className.toLowerCase().replace(' ','-') %>" class="button-link" style="display:inline-block;margin-top:1.5rem;padding:.6rem 1.5rem;background:#0b2a4a;color:#fff;border-radius:10px;text-decoration:none"><i class="fas fa-arrow-left"></i> Back to Portal</a>
    </div>
    <div class="panel-card" style="padding:1.5rem;margin-bottom:1.5rem">
      <h2 style="margin-top:0"><i class="fas fa-list-check"></i> Answer Review</h2>
      <% result.answers.forEach((ans, i) => { %>
        <% const q = quiz.questions[i]; %>
        <% const isCorrect = ans.teacherOverride !== null ? ans.teacherOverride : ans.autoCorrect; %>
        <div style="background:#faf8f5;border:1px solid #ece4d9;border-radius:10px;padding:.75rem 1rem;margin-bottom:.6rem;border-left:4px solid <%= isCorrect?'#27ae60':'#e74c3c' %>">
          <div style="font-weight:600;color:#0b2a4a"><%= i+1 %>. <%= q.questionText %></div>
          <div style="margin-top:.3rem;font-size:.9rem">
            <span>Your answer: <strong><%= q.type==='mcq' ? (q.options[parseInt(ans.answer)] || ans.answer) : ans.answer || '(no answer)' %></strong></span>
            <span style="margin-left:.5rem;color:<%= isCorrect?'#27ae60':'#e74c3c' %>;font-weight:600"><%= isCorrect ? '✅' : '❌' %></span>
          </div>
          <% if (!isCorrect) { %>
            <div style="margin-top:.2rem;font-size:.85rem;color:#27ae60">
              Correct answer: 
              <% if (q.type === 'mcq') { %><strong><%= q.options[q.correctIndex] %></strong><% } %>
              <% if (q.type === 'truefalse') { %><strong><%= q.correctAnswer === 'true' ? 'True' : 'False' %></strong><% } %>
              <% if (q.type === 'shortanswer') { %><strong><%= q.correctAnswer %></strong><% } %>
            </div>
          <% } %>
        </div>
      <% }) %>
      <a href="/portal/<%= quiz.className.toLowerCase().replace(' ','-') %>" class="button-link" style="display:inline-block;margin-top:1rem;padding:.6rem 1.5rem;background:#0b2a4a;color:#fff;border-radius:10px;text-decoration:none"><i class="fas fa-arrow-left"></i> Back to Portal</a>
    </div>
    <script>
    (function() {
      const done = JSON.parse(localStorage.getItem('ehmej_quizzes') || '[]');
      if (!done.includes('<%= quiz._id %>')) {
        done.push('<%= quiz._id %>');
        localStorage.setItem('ehmej_quizzes', JSON.stringify(done));
      }
    })();
    </script>
  <% } else { %>
    <form method="POST" action="/portal/quiz/<%= quiz._id %>" class="stack-form" style="background:#fff;border-radius:16px;padding:1.5rem;box-shadow:0 10px 24px rgba(11,42,74,.08);border:1px solid #e8ddd0">
      <div style="margin-bottom:1rem">
        <label style="font-weight:700;color:#0b2a4a;display:block;margin-bottom:.3rem"><i class="fas fa-user"></i> Your Name</label>
        <input type="text" name="studentName" placeholder="Enter your full name" value="<%= studentName %>" required style="width:100%;padding:12px 14px;border:2px solid #e8ddd0;border-radius:10px;font-size:.95rem">
      </div>
      <input type="hidden" name="answers" id="answersJson">
      <div style="margin-bottom:1rem">
        <p style="color:#667588;font-size:.88rem"><strong><%= quiz.questions.length %></strong> question<%= quiz.questions.length!==1?'s':'' %></p>
      </div>
      <% quiz.questions.forEach((q, i) => { %>
        <div class="question-block" style="background:#faf8f5;border:1px solid #ece4d9;border-radius:12px;padding:1rem;margin-bottom:1rem">
          <div class="question-text" style="font-weight:600;color:#0b2a4a;margin-bottom:.6rem;font-size:1rem"><%= i+1 %>. <%= q.questionText %></div>
          <% if (q.type === 'mcq') { %>
            <div class="quiz-options">
              <% q.options.forEach((opt, j) => { %>
                <div class="quiz-option" style="margin-bottom:.4rem">
                  <label style="display:flex;align-items:center;gap:.5rem;padding:.5rem .75rem;border:2px solid #e8ddd0;border-radius:8px;cursor:pointer;transition:.2s;background:#fff" onmouseover="this.style.borderColor='#b8944e'" onmouseout="this.style.borderColor='#e8ddd0'">
                    <input type="radio" name="q<%= i %>" value="<%= j %>" onchange="setAnswer(<%= i %>, this.value)" style="width:auto;margin:0;accent-color:#0b2a4a">
                    <span><%= opt %></span>
                  </label>
                </div>
              <% }) %>
            </div>
          <% } else if (q.type === 'truefalse') { %>
            <div class="quiz-options" style="display:flex;gap:1rem">
              <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:.5rem;padding:.7rem;border:2px solid #e8ddd0;border-radius:8px;cursor:pointer;transition:.2s;background:#fff" onmouseover="this.style.borderColor='#b8944e'" onmouseout="this.style.borderColor='#e8ddd0'">
                <input type="radio" name="q<%= i %>" value="true" onchange="setAnswer(<%= i %>, this.value)" style="width:auto;margin:0;accent-color:#0b2a4a"> True
              </label>
              <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:.5rem;padding:.7rem;border:2px solid #e8ddd0;border-radius:8px;cursor:pointer;transition:.2s;background:#fff" onmouseover="this.style.borderColor='#b8944e'" onmouseout="this.style.borderColor='#e8ddd0'">
                <input type="radio" name="q<%= i %>" value="false" onchange="setAnswer(<%= i %>, this.value)" style="width:auto;margin:0;accent-color:#0b2a4a"> False
              </label>
            </div>
          <% } else { %>
            <input type="text" placeholder="Type your answer" onchange="setAnswer(<%= i %>, this.value)" style="width:100%;padding:10px 14px;border:2px solid #e8ddd0;border-radius:8px;font-size:.9rem">
          <% } %>
        </div>
      <% }) %>
      <button type="submit" onclick="return submitQuiz()" style="width:100%;padding:14px;font-size:1rem;font-weight:700"><i class="fas fa-paper-plane"></i> Submit Quiz</button>
    </form>
  <% } %>
  <div style="text-align:center;margin-top:2rem;padding:1.5rem 0;color:#999;border-top:1px solid #e9ecef">
    <p>&copy; 2026 École Officielle Ehmej · Maths Platform</p>
  </div>
</div>
<script>
let studentAnswers = [];
function setAnswer(index, value) {
  const existing = studentAnswers.findIndex(a => a.questionIndex === index);
  if (existing >= 0) studentAnswers[existing].answer = value;
  else studentAnswers.push({questionIndex: index, answer: value});
}
function submitQuiz() {
  const studentName = document.querySelector('[name="studentName"]').value.trim();
  if (!studentName) { alert('Please enter your name.'); return false; }
  document.getElementById('answersJson').value = JSON.stringify(studentAnswers);
  return true;
}
</script>
</body>
</html>

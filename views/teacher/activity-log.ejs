<!DOCTYPE html>
<html>
<head><title>Activity Log</title><link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"></head>
<body>
<%- include('../partials/header') %>
<div class="container">
  <div class="page-hero">
    <p class="eyebrow">History</p>
    <h1><i class="fas fa-history"></i> Grade Activity Log</h1>
    <p>Filter by action type or search for a student name.</p>
  </div>
  <form method="GET" action="/teacher/activity-log" class="filter-section">
    <label for="af"><i class="fas fa-tag"></i> Action:</label>
    <select id="af" name="action">
      <option value="all" <%= selectedAction==='all'?'selected':'' %>>All Actions</option>
      <option value="grade_saved" <%= selectedAction==='grade_saved'?'selected':'' %>>Grade Saved</option>
      <option value="year_exam_saved" <%= selectedAction==='year_exam_saved'?'selected':'' %>>Exam Saved</option>
    </select>
    <label for="si"><i class="fas fa-search"></i> Student:</label>
    <input type="text" id="si" name="search" placeholder="Search by name" value="<%= search %>">
    <button type="submit"><i class="fas fa-filter"></i> Filter</button>
  </form>
  <div class="table-responsive">
    <table>
      <thead><tr><th>Date</th><th>Student</th><th>Action</th><th>Details</th></tr></thead>
      <tbody>
        <% activities.forEach(a => { %>
          <tr>
            <td><%= a.createdAt.toLocaleDateString() %> <%= a.createdAt.toLocaleTimeString() %></td>
            <td><%= a.studentName||'Unknown' %></td>
            <td><span class="class-badge"><%= a.action.replace('_',' ') %></span></td>
            <td><%= a.details||'' %></td>
          </tr>
        <% }) %>
        <% if (activities.length===0) { %><tr><td colspan="4" class="text-center">No activity recorded yet.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
</body>
</html>
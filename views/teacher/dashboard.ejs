<!DOCTYPE html>
<html>
<head><title>Dashboard</title><meta name="viewport" content="width=device-width, initial-scale=1"><link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"></head>
<body>
<%- include('../partials/header') %>
<div class="container">
  <div class="page-hero">
    <p class="eyebrow">Academic Year <%= currentYear %></p>
    <h1><i class="fas fa-chart-pie"></i> Dashboard</h1>
    <p style="font-size:1.1rem;font-weight:500;color:#1a2a3a;margin-top:.5rem">Hello, teacher Boutros!</p>
  </div>
  <div class="stats-grid">
    <div class="stat-card"><span><i class="fas fa-users"></i> Total Students</span><strong><%= students.length %></strong></div>
    <div class="stat-card"><span><i class="fas fa-chart-bar"></i> Overall Average</span><strong><%= overallAverage.toFixed(1) %></strong></div>
  </div>
  <section class="panel-card">
    <div class="section-heading">
      <h2><i class="fas fa-layer-group"></i> Per-Class Semester Averages</h2>
      <p>Mean final score (/60) by class and term.</p>
    </div>
    <div class="table-responsive">
      <table class="compact-table">
        <thead><tr><th>Class</th><th>Students</th><th>S1</th><th>S2</th><th>Mid</th><th>S3</th><th>S4</th><th>Final</th></tr></thead>
        <tbody>
          <% classAverages.forEach(c => { %>
            <tr>
              <td><span class="class-badge"><%= c.className %></span></td>
              <td><strong><%= c.count %></strong></td>
              <% c.semesters.forEach(avg => { %>
                <td class="<%= avg>=30?'avg-pass':avg>=24?'avg-border':'avg-fail' %>"><%= avg.toFixed(1) %></td>
              <% }) %>
            </tr>
          <% }) %>
          <% if (classAverages.every(c=>c.count===0)) { %><tr><td colspan="8" class="text-center">No students enrolled.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </section>
</div>
</body>
</html>
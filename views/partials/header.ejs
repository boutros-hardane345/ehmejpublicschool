<header class="main-header">
  <div class="header-row">
    <div class="logo"><i class="fas fa-calculator"></i> École Officielle Ehmej</div>
    <button class="hamburger" onclick="document.querySelector('.main-header nav').classList.toggle('open')" aria-label="Menu"><i class="fas fa-bars"></i></button>
  </div>
  <nav id="mainNav">
    <a href="/teacher/dashboard"><i class="fas fa-chart-pie"></i> Dashboard</a>
    <a href="/teacher/students"><i class="fas fa-users"></i> Students</a>
    <a href="/teacher/schedule"><i class="fas fa-calendar-alt"></i> Schedule</a>
    <a href="/teacher/content"><i class="fas fa-layer-group"></i> Content</a>
    <a href="/teacher/grades"><i class="fas fa-star"></i> Grades</a>
    <a href="/teacher/year-results"><i class="fas fa-book-open"></i> Year</a>
    <a href="/logout" class="logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </nav>
  <script>for(const a of document.getElementById('mainNav').querySelectorAll('a:not(.logout)')){if(a.href.replace(/\/$/,'')===window.location.href.replace(/\/$/,''))a.classList.add('active')}</script>
</header>
<div class="quote-banner">
  <p class="quote-banner-label">Daily Mathematical Thought</p>
  <p class="quote-banner-text">"<%= dailyMathQuote.text %>"</p>
  <p class="quote-banner-author"><%= dailyMathQuote.author %></p>
</div>

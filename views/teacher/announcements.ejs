<!DOCTYPE html>
<html>
<head><title>Announcements</title><meta name="viewport" content="width=device-width,initial-scale=1"><link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"></head>
<body>
<%- include('../partials/header') %>
<div class="container">
  <h1><i class="fas fa-bullhorn"></i> Announcements</h1>
  <form method="POST" action="/teacher/announcements">
    <select name="className" required><option value="Grade 7">Grade 7</option><option value="Grade 8">Grade 8</option><option value="Grade 9">Grade 9</option></select>
    <input type="text" name="title" placeholder="Title" required>
    <textarea name="content" placeholder="Content" required rows="2"></textarea>
    <button type="submit"><i class="fas fa-plus"></i> Post</button>
  </form>
  <div class="announcements-list">
    <% announcements.forEach(a=>{%>
      <div class="portal-item">
        <h3><%=a.title%></h3><p><%=a.content%></p>
        <small><%=a.className%> · <%=a.createdAt.toLocaleDateString()%> <%=a.createdAt.toLocaleTimeString()%></small>
        <form method="POST" action="/teacher/announcements/delete/<%=a._id%>" style="display:inline;margin-top:10px"><button type="submit" class="btn-delete" onclick="return confirm('Delete?')"><i class="fas fa-trash"></i> Delete</button></form>
      </div>
    <%})%>
    <% if (announcements.length===0) {%><p class="text-center">No announcements yet</p><%}%>
  </div>
</div>
</body>
</html>
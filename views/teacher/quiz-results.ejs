<!DOCTYPE html>
<html>
<head><title>Quiz Results</title><meta name="viewport" content="width=device-width,initial-scale=1"><link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"></head>
<body>
<%- include('../partials/header') %>
<div class="container">
  <div class="page-hero">
    <p class="eyebrow"><a href="/teacher/content" style="color:#a0773b;text-decoration:none"><i class="fas fa-arrow-left"></i> Back to Content</a></p>
    <h1><i class="fas fa-chart-bar"></i> <%= quiz.title %></h1>
    <p><span class="class-badge"><%= quiz.className %></span> <% if (quiz.semester) { %><span class="class-badge">Semester <%= quiz.semester %></span><% } %></p>
  </div>
  <% if (quiz.questions && quiz.questions.length > 0) { %>
    <div class="panel-card" style="margin-bottom:1.5rem">
      <div class="section-heading"><h2><i class="fas fa-question-circle"></i> Questions</h2><p>Review the quiz content.</p></div>
      <div style="display:grid;gap:.75rem">
        <% quiz.questions.forEach((q, i) => { %>
          <div style="background:#faf8f5;border:1px solid #ece4d9;border-radius:10px;padding:.75rem 1rem">
            <strong style="color:#0b2a4a"><%= i+1 %>. <%= q.questionText %></strong>
            <span class="class-badge" style="margin-left:.5rem;font-size:.7rem"><%= q.type==='mcq'?'Multiple Choice':q.type==='truefalse'?'True/False':'Short Answer' %></span>
            <% if (q.type==='mcq' && q.options) { %>
              <div style="margin-top:.3rem;font-size:.85rem;color:#555">
                <% q.options.forEach((o, j) => { %>
                  <div><%= j===q.correctIndex?'✅ ':'' %><%= o %></div>
                <% }) %>
              </div>
            <% } else if (q.type==='truefalse') { %>
              <div style="margin-top:.3rem;font-size:.85rem;color:#555">Answer: <%= q.correctAnswer==='true'?'✅ True':'✅ False' %></div>
            <% } else { %>
              <div style="margin-top:.3rem;font-size:.85rem;color:#555">Answer: <%= q.correctAnswer||'(not set)' %></div>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
  <div class="panel-card">
    <div class="section-heading"><h2><i class="fas fa-users"></i> Attempts (<%= attempts.length %>)</h2><p>Student scores and answer review.</p></div>
    <% if (attempts.length > 0) { %>
      <div class="table-responsive">
        <table>
          <thead><tr><th>Student</th><th>Score</th><th>Percent</th><th>Date</th><th>Review</th></tr></thead>
          <tbody>
            <% attempts.forEach(a => { %>
              <tr>
                <td><strong><%= a.studentName %></strong></td>
                <td><%= a.score %> / <%= a.total %></td>
                <td><span class="status-badge <%= (a.score/a.total*100)>=50?'status-pass':(a.score/a.total*100)>=40?'status-border':'status-fail' %>"><%= Math.round(a.score/a.total*100) %>%</span></td>
                <td><%= a.submittedAt.toLocaleDateString() %> <%= a.submittedAt.toLocaleTimeString() %></td>
                <td><button onclick="toggleReview('<%= a._id %>')" class="btn-delete" style="background:#0b2a4a;color:#fff;border:none"><i class="fas fa-eye"></i> View</button></td>
              </tr>
              <tr id="review-<%= a._id %>" style="display:none">
                <td colspan="5" style="padding:1rem;background:#f8f6f3">
                  <div style="display:grid;gap:.6rem">
                    <% a.answers.forEach((ans, j) => { %>
                      <% const q = quiz.questions[j]; %>
                      <div style="background:#fff;border:1px solid #ece4d9;border-radius:8px;padding:.6rem .8rem">
                        <div style="font-weight:600;color:#0b2a4a;font-size:.88rem"><%= j+1 %>. <%= q.questionText %></div>
                        <div style="margin-top:.2rem;font-size:.85rem;color:#555">Student answer: <strong><%= ans.answer || '(no answer)' %></strong></div>
                        <div style="margin-top:.2rem;font-size:.85rem">
                          <% const isCorrect = ans.teacherOverride !== null ? ans.teacherOverride : ans.autoCorrect; %>
                          <span style="color:<%= isCorrect?'#27ae60':'#e74c3c' %>;font-weight:600">
                            <%= isCorrect ? '✅ Correct' : '❌ Incorrect' %>
                          </span>
                          <% if (q.type === 'shortanswer') { %>
                            <button onclick="toggleOverride('<%= a._id %>', <%= j %>, <%= ans.teacherOverride === true %>)" style="margin-left:.5rem;padding:2px 8px;border-radius:6px;border:1px solid #b8944e;background:#fff;color:#0b2a4a;cursor:pointer;font-size:.75rem">
                              <%= ans.teacherOverride !== null ? 'Revert' : 'Override' %>
                            </button>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="empty-state" style="padding:2rem;text-align:center;color:#999;font-style:italic">No attempts yet.</p>
    <% } %>
  </div>
</div>
<script>
function toggleReview(id) {
  const row = document.getElementById('review-' + id);
  row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
}
async function toggleOverride(attemptId, questionIndex, currentOverride) {
  const newValue = !currentOverride;
  if (!confirm('Set this answer to ' + (newValue ? 'correct' : 'incorrect') + '?')) return;
  try {
    const res = await fetch('/teacher/quizzes/override/' + attemptId, {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({questionIndex, value: newValue})
    });
    const data = await res.json();
    if (data.success) location.reload();
  } catch(e) { alert('Error'); }
}
</script>
</body>
</html>

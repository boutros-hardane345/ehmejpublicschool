<!DOCTYPE html>
<html>
<head><title>Manage Grades</title><meta name="viewport" content="width=device-width,initial-scale=1"><link rel="stylesheet" href="/css/style.css"><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"></head>
<body>
<%- include('../partials/header') %>
<div class="container">
  <div class="page-hero">
    <p class="eyebrow">Assessment Center</p>
    <h1><i class="fas fa-table"></i> Semester Grades</h1>
    <p>Enter scores for each period. Attendance /6, DS /10 each, Big Exam /20. Final score is converted to /60.</p>
  </div>
  <form method="GET" action="/teacher/grades" class="filter-section">
    <label for="cf"><i class="fas fa-filter"></i> Class:</label>
    <select id="cf" name="class"><option value="all">All</option><% classes.forEach(c=>{%><option value="<%=c%>" <%=selectedClass===c?'selected':''%>><%=c%></option><%})%></select>
    <label for="yf"><i class="fas fa-calendar"></i> Year:</label>
    <select id="yf" name="year"><% academicYears.forEach(y=>{%><option value="<%=y%>" <%=selectedYear===y?'selected':''%>><%=y%></option><%})%></select>
    <label for="pf"><i class="fas fa-book"></i> Period:</label>
    <select id="pf" name="semester">
      <% periods.forEach(p=>{%><option value="<%=p%>" <%=selectedSemester===String(p)?'selected':''%>><%=periodLabels[p]%></option><%})%>
    </select>
    <button type="submit"><i class="fas fa-search"></i> View</button>
    <button type="button" onclick="exportGradesPDF()"><i class="fas fa-file-pdf"></i> Export PDF</button>
  </form>
  <section class="panel-card">
    <div class="section-heading"><h2><i class="fas fa-edit"></i> Grade Entry</h2><p>Select student and period, then enter scores.</p></div>
    <form method="POST" action="/teacher/grades" class="grade-form">
      <select name="studentId" required><option value="">Select Student</option><% students.forEach(s=>{%><option value="<%=s._id%>"><%=s.name%> (<%=s.className%> - <%=s.academicYear||'Not set'%>)</option><%})%></select>
      <select name="semester" required><option value="">Period</option><% periods.forEach(p=>{%><option value="<%=p%>"><%=periodLabels[p]%></option><%})%></select>
      <input type="number" name="attendance" placeholder="Attendance /6" min="0" max="6" step="0.5" required>
      <input type="number" name="ds1" placeholder="DS1 /10" min="0" max="10" step="0.5" required>
      <input type="number" name="ds2" placeholder="DS2 /10" min="0" max="10" step="0.5" required>
      <input type="number" name="ds3" placeholder="DS3 /10" min="0" max="10" step="0.5" required>
      <input type="number" name="bigExam" placeholder="Big Exam /20" min="0" max="20" step="0.5" required>
      <button type="submit"><i class="fas fa-save"></i> Save Grade</button>
    </form>
  </section>
  <section class="panel-card">
    <div class="section-heading"><h2><i class="fas fa-table"></i> Grades — <%= periodLabels[parseInt(selectedSemester)]||'All Periods' %></h2><p><%= grades.length %> grade<%= grades.length===1?'':'s' %> recorded.</p></div>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Student</th><th>Class</th><th>Year</th><th>Period</th><th>Att /6</th>
            <th>DS1 /10</th><th>DS2 /10</th><th>DS3 /10</th>
            <th>Exam /20</th><th>Raw</th><th>Final /60</th>
          </tr>
        </thead>
        <tbody>
          <% grades.forEach(g=>{const s=students.find(s=>s._id.toString()===g.studentId.toString());if(!s)return;%>
            <tr>
              <td><%=s.name%></td><td><span class="class-badge"><%=s.className%></span></td><td><%=s.academicYear||'Not set'%></td>
              <td><%=periodLabels[g.semester]||'S'+g.semester%></td><td><%=g.attendance%></td>
              <td><%=g.ds[0]||0%></td><td><%=g.ds[1]||0%></td><td><%=g.ds[2]||0%></td>
              <td><%=g.bigExam%></td><td><strong><%=g.rawTotal%></strong></td>
              <td><strong class="final-grade"><%=g.final60.toFixed(1)%></strong></td>
            </tr>
          <%})%>
          <% if (grades.length===0) { %><tr><td colspan="11" class="text-center">No grades saved for this period.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </section>
</div>
<script>function exportGradesPDF(){const p=new URLSearchParams({class:document.getElementById('cf').value,year:document.getElementById('yf').value,semester:document.getElementById('pf').value});window.location.href='/teacher/export-semester-pdf?'+p.toString()}</script>
</body>
</html>

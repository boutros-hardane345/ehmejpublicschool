<header class="main-header">
  <div class="header-shell">
    <a class="brand" href="/teacher/dashboard" aria-label="École Officielle Ehmej dashboard">
      <span class="brand-mark"><i class="fas fa-calculator"></i></span>
      <span class="brand-copy"><strong>École Officielle Ehmej</strong><small>Maths Teacher Platform</small></span>
    </a>
    <button class="hamburger" type="button" aria-label="Open navigation menu" aria-controls="mainNav" aria-expanded="false"><i class="fas fa-bars"></i></button>
    <nav id="mainNav" aria-label="Teacher navigation">
      <a href="/teacher/dashboard"><i class="fas fa-chart-pie"></i><span>Dashboard</span></a>
      <a href="/teacher/students"><i class="fas fa-users"></i><span>Students</span></a>
      <a href="/teacher/content"><i class="fas fa-layer-group"></i><span>Content</span></a>
      <a href="/teacher/grades"><i class="fas fa-star"></i><span>Grades</span></a>
      <a href="/teacher/year-results"><i class="fas fa-book-open"></i><span>Year Results</span></a>
      <a href="/logout" class="logout"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
    </nav>
  </div>
  <script>
    const mainNav = document.getElementById('mainNav');
    const navToggle = document.querySelector('.hamburger');
    for (const link of mainNav.querySelectorAll('a:not(.logout)')) {
      if (link.href.replace(/\/$/, '') === window.location.href.replace(/\/$/, '')) {
        link.classList.add('active');
        link.setAttribute('aria-current', 'page');
      }
    }
    navToggle.addEventListener('click', () => {
      const isOpen = mainNav.classList.toggle('open');
      navToggle.setAttribute('aria-expanded', String(isOpen));
      navToggle.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    });
  </script>
</header>
<div class="quote-banner">
  <p class="quote-banner-label">Daily Mathematical Thought</p>
  <p class="quote-banner-text">"<%= dailyMathQuote.text %>"</p>
  <p class="quote-banner-author"><%= dailyMathQuote.author %></p>
</div>

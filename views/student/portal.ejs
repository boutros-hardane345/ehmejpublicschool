<!DOCTYPE html>
<html>
<head>
  <title>Student Portal</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
  <div class="portal-container">
    <div class="portal-header">
      <h1><i class="fas fa-graduation-cap"></i> École Officielle Ehmej · <%= selectedClass||'Student Portal' %></h1>
      <% if (isGradeLanding) { %>
        <p>Open the page for your class to see announcements and exercises.</p>
      <% } else { %>
        <p>Access announcements and exercises for <%= selectedClass %>.</p>
      <% } %>
    </div>
    <div class="portal-quote">
      <p class="quote-banner-label">Daily Mathematical Thought</p>
      <p class="quote-banner-text">"<%= dailyMathQuote.text %>"</p>
      <p class="quote-banner-author"><%= dailyMathQuote.author %></p>
    </div>
    <% if (isGradeLanding) { %>
      <div class="portal-directory">
        <h2>Select Your Class</h2>
        <ul>
          <% classes.forEach(c => { %>
            <li><a href="/portal/<%= c.toLowerCase().replace(' ','-') %>"><%= c %></a></li>
          <% }) %>
        </ul>
      </div>
    <% } else { %>
      <div class="portal-filters">
        <form method="GET" action="<%= portalPath %>" class="filter-form">
          <label for="monthInput"><i class="fas fa-calendar"></i> Month:</label>
          <input type="month" name="month" id="monthInput" value="<%= month||'' %>">
          <label for="semesterInput"><i class="fas fa-book"></i> Semester:</label>
          <input type="number" name="semester" id="semesterInput" placeholder="1-4" min="1" max="4" value="<%= semester||'' %>">
          <button type="submit"><i class="fas fa-filter"></i> Filter</button>
          <a href="<%= portalPath %>" class="clear-btn"><i class="fas fa-times"></i> Clear</a>
        </form>
      </div>
      <div class="portal-content">
        <div class="portal-section">
          <h2 style="color:#0b2a4a;border-bottom:3px solid #0b2a4a;padding-bottom:.5rem;margin-bottom:1.5rem"><i class="fas fa-bullhorn"></i> Announcements</h2>
          <% if (announcements&&announcements.length>0) { %>
            <% announcements.forEach(a => { %>
              <div class="portal-item">
                <h3><%= a.title %></h3>
                <p><%= a.content %></p>
                <div class="meta">
                  <span><i class="fas fa-tag"></i> <%= a.className %></span>
                  <span><i class="fas fa-clock"></i> <%= new Date(a.createdAt).toLocaleDateString() %></span>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="no-items" style="color:#999;text-align:center;padding:2rem;font-style:italic"><i class="fas fa-info-circle"></i><p>No announcements available.</p></div>
          <% } %>
        </div>
        <div class="portal-section">
          <h2 style="color:#0b2a4a;border-bottom:3px solid #0b2a4a;padding-bottom:.5rem;margin-bottom:1.5rem"><i class="fas fa-file-download"></i> Exercises</h2>
          <% if (exercises&&exercises.length>0) { %>
            <% exercises.forEach(e => { %>
              <div class="portal-item">
                <h3><%= e.title %></h3>
                <p><%= e.description||'No description provided.' %></p>
                <% if (e.fileUrl) { %>
                  <a href="<%= e.fileUrl %>" class="download-btn" style="display:inline-block;margin-top:.5rem;padding:6px 16px;background:#0b2a4a;color:#fff;text-decoration:none;border-radius:6px;font-size:.9rem;transition:.2s" download><i class="fas fa-download"></i> Download Exercise</a>
                <% } else { %>
                  <span style="color:#999;font-size:.9rem"><i class="fas fa-file"></i> No file attached</span>
                <% } %>
                <div class="meta">
                  <span><i class="fas fa-tag"></i> <%= e.className %></span>
                  <% if (e.semester) { %><span><i class="fas fa-book"></i> Semester <%= e.semester %></span><% } %>
                  <span><i class="fas fa-clock"></i> <%= new Date(e.createdAt).toLocaleDateString() %></span>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="no-items" style="color:#999;text-align:center;padding:2rem;font-style:italic"><i class="fas fa-info-circle"></i><p>No exercises available.</p></div>
          <% } %>
        </div>
        <!-- Quizzes Section -->
        <div class="portal-section" style="margin-top:1.5rem;grid-column:span 2">
          <h2 style="color:#0b2a4a;border-bottom:3px solid #b8944e;padding-bottom:.5rem;margin-bottom:1.5rem"><i class="fas fa-question-circle"></i> Quizzes</h2>
          <% if (quizzes&&quizzes.length>0) { %>
            <% quizzes.forEach(q => { %>
              <div class="portal-item" data-quiz-id="<%= q._id %>">
                <h3><%= q.title %></h3>
                <p style="color:#667588;font-size:.85rem"><%= q.questions.length %> question<%= q.questions.length!==1?'s':'' %><% if (q.semester) { %> · Semester <%= q.semester %><% } %></p>
                <div class="quiz-actions" style="display:flex;gap:.5rem;align-items:center;flex-wrap:wrap;margin-top:.5rem">
                  <a href="/portal/quiz/<%= q._id %>" class="download-btn" style="display:inline-block;padding:6px 16px;background:#0b2a4a;color:#fff;text-decoration:none;border-radius:6px;font-size:.9rem;transition:.2s"><i class="fas fa-pencil-alt"></i> Take Quiz</a>
                </div>
                <div class="meta">
                  <span><i class="fas fa-tag"></i> <%= q.className %></span>
                  <span><i class="fas fa-clock"></i> <%= new Date(q.createdAt).toLocaleDateString() %></span>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="no-items" style="color:#999;text-align:center;padding:2rem;font-style:italic"><i class="fas fa-info-circle"></i><p>No quizzes available.</p></div>
          <% } %>
        </div>
        <script>
        (function() {
          const done = JSON.parse(localStorage.getItem('ehmej_quizzes') || '[]');
          document.querySelectorAll('[data-quiz-id]').forEach(el => {
            if (done.includes(el.dataset.quizId)) {
              const btn = el.querySelector('.quiz-actions');
              if (btn) btn.innerHTML += '<span style="background:#27ae60;color:#fff;padding:6px 12px;border-radius:6px;font-size:.8rem;font-weight:600">✅ Completed</span>';
            }
          });
        })();
        </script>
      </div>
    <% } %>
    <div style="text-align:center;margin-top:3rem;padding:2rem 0;color:#999;border-top:1px solid #e9ecef">
      <a href="https://wa.me/96181239091" target="_blank" rel="noopener" class="whatsapp-btn"><i class="fab fa-whatsapp" style="font-size:1.3rem"></i> Chat WhatsApp</a>
      <p>&copy; 2026 École Officielle Ehmej · Maths Platform</p>
    </div>
  </div>
</body>
</html>